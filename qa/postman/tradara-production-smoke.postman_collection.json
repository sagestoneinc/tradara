  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('api_base_url is configured', function () {",
          "  pm.expect(pm.collectionVariables.get('api_base_url') || pm.environment.get('api_base_url')).to.be.a('string').and.not.empty;",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test('response is not a server error', function () {",
          "  pm.expect(pm.response.code).to.be.below(500);",
          "});",
          "",
          "var contentType = pm.response.headers.get('Content-Type') || '';",
          "if (contentType.indexOf('application/json') !== -1) {",
          "  var body = pm.response.json();",
          "  pm.test('json response parses', function () {",
          "    pm.expect(body).to.be.an('object');",
          "  });",
          "",
          "  if (Object.prototype.hasOwnProperty.call(body, 'success')) {",
          "    pm.test('success envelope has a data payload', function () {",
          "      pm.expect(body.success).to.be.a('boolean');",
          "      pm.expect(body).to.have.property('data');",
          "    });",
          "  }",
          "}"
        ]
      }
    }
  ],
