generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlanId {
  tradara_pro_monthly
  tradara_pro_quarterly
  tradara_pro_annual
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  grace_period
  canceled
  expired
}

enum ChannelAccessStatus {
  pending_grant
  granted
  pending_revoke
  revoked
  error
}

enum AccessDesiredState {
  grant
  revoke
}

enum TelegramInviteStatus {
  pending
  issued
  consumed
  expired
  failed
}

enum WebhookProvider {
  telegram
  paymongo
  paypal
  xendit
  tradingview
}

enum TelegramExecutionStatus {
  idle
  attempting
  retrying
  succeeded
  failed_retryable
  failed_non_retryable
}

enum TelegramFailureKind {
  retryable
  non_retryable
}

enum AuditActorType {
  system
  admin
  job
  webhook
}

enum SignalStatus {
  draft
  ai_scored
  pending_review
  approved
  edited
  rejected
  published
  canceled
}

enum SignalSourceType {
  tradingview
  manual
  ai_assisted
}

enum TradeDirection {
  long
  short
  neutral
}

enum RiskLabel {
  low
  medium
  high
}

enum MarketInsightStatus {
  draft
  pending_review
  approved
  published
  rejected
  canceled
}

model User {
  id             String          @id
  email          String?         @unique
  telegramUserId String?         @unique
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  subscriptions  Subscription[]
  channelAccess  ChannelAccess[]
  auditLogs      AuditLog[]
  invites        TelegramInvite[]
}

model Subscription {
  id                     String             @id
  userId                 String
  planId                 SubscriptionPlanId
  status                 SubscriptionStatus
  providerName           WebhookProvider?
  providerCustomerId     String?
  providerSubscriptionId String?
  currentPeriodEndsAt    DateTime
  gracePeriodEndsAt      DateTime?
  canceledAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelAccessRecords   ChannelAccess[]
}

model ChannelAccess {
  id                    String                  @id
  userId                String
  subscriptionId        String?
  channelId             String
  telegramUserId        String?
  status                ChannelAccessStatus
  desiredState          AccessDesiredState
  inviteId              String?
  lastSyncedAt          DateTime?
  lastError             String?
  lastErrorCode         String?
  lastFailureKind       TelegramFailureKind?
  executionStatus       TelegramExecutionStatus?
  executionAttempts     Int?
  lastExecutionAttemptAt DateTime?
  lastExecutionOutcomeAt DateTime?
  lastCorrelationId     String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription          Subscription?           @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  invites               TelegramInvite[]
}

model TelegramInvite {
  id         String               @id
  accessId   String?
  userId     String
  channelId  String
  inviteUrl  String?
  status     TelegramInviteStatus
  expiresAt  DateTime?
  note       String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  access     ChannelAccess?       @relation(fields: [accessId], references: [id], onDelete: SetNull)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id              String          @id
  provider        WebhookProvider
  providerEventId String
  payloadHash     String
  signatureValid  Boolean
  processedAt     DateTime?
  receivedAt      DateTime        @default(now())

  @@unique([provider, providerEventId])
}

model AuditLog {
  id         String         @id
  userId     String?
  actorType  AuditActorType
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json
  createdAt  DateTime       @default(now())
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model SignalInput {
  id                    String            @id
  sourceType            SignalSourceType
  sourceProvider        WebhookProvider?
  sourceEventId         String?
  symbol                String
  timeframe             String?
  direction             TradeDirection?
  entryZoneLow          Decimal?
  entryZoneHigh         Decimal?
  stopLoss              Decimal?
  takeProfit1           Decimal?
  takeProfit2           Decimal?
  takeProfit3           Decimal?
  marketPrice           Decimal?
  trendAlignment        Int?
  structureQuality      Int?
  volatilityQuality     Int?
  liquidityQuality      Int?
  riskRewardQuality     Int?
  conflictPenalty       Int?
  note                  String?
  strategyName          String?
  detectedAt            DateTime?
  metadata              Json
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  signal                Signal?

  @@index([sourceType, createdAt])
  @@index([sourceProvider, sourceEventId])
}

model Signal {
  id                    String            @id
  signalInputId         String            @unique
  status                SignalStatus
  sourceType            SignalSourceType
  confidenceScore       Int?
  setupQualityScore     Int?
  riskLabel             RiskLabel?
  invalidationSummary   String?
  setupRationale        String?
  marketContext         String?
  warnings              Json
  confidenceBreakdown   Json
  telegramDraft         String?
  expertReviewNotes     String?
  editedTelegramDraft   String?
  publishedTelegramText String?
  publishedTelegramChatId String?
  publishedTelegramMessageId String?
  approvedBy            String?
  approvedAt            DateTime?
  rejectedBy            String?
  rejectedAt            DateTime?
  publishedBy           String?
  publishedAt           DateTime?
  canceledAt            DateTime?
  metadata              Json
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  signalInput           SignalInput       @relation(fields: [signalInputId], references: [id], onDelete: Cascade)
  reviews               SignalReview[]

  @@index([status, createdAt])
}

model SignalReview {
  id                String        @id
  signalId          String
  reviewerId        String
  resultingStatus   SignalStatus
  notes             String?
  editedTelegramDraft String?
  createdAt         DateTime      @default(now())
  signal            Signal        @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId, createdAt])
  @@index([reviewerId, createdAt])
}

model MarketInsight {
  id                  String              @id
  status              MarketInsightStatus
  symbol              String
  timeframe           String?
  title               String
  summary             String
  body                String
  telegramDraft       String?
  approvedBy          String?
  approvedAt          DateTime?
  publishedBy         String?
  publishedAt         DateTime?
  rejectedBy          String?
  rejectedAt          DateTime?
  canceledAt          DateTime?
  metadata            Json
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([status, createdAt])
}
