NODE_ENV=production
BOT_API_PORT=3001
BOT_API_BASE_URL=https://tradara-api.sagestonelab.tech
MARKETING_SITE_BASE_URL=https://tradara.sagestonelab.tech
DATABASE_URL=postgresql://user:password@host:5432/dbname

TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_WEBHOOK_SECRET=replace-me
TELEGRAM_PREMIUM_CHANNEL_ID=-1000000000000
TELEGRAM_BOT_USERNAME=tradara_bot

TRADINGVIEW_WEBHOOK_SECRET=replace-me
ACCESS_GRACE_PERIOD_HOURS=72

BILLING_PROVIDER_PAYPAL_ENABLED=true
BILLING_PROVIDER_XENDIT_ENABLED=true
PAYMENT_PROVIDER_PAYPAL_WEIGHT=50
PAYMENT_PROVIDER_XENDIT_WEIGHT=50
PAYMENT_PROVIDER_PAYMONGO_WEIGHT=0

PAYPAL_CLIENT_ID=replace-me
PAYPAL_CLIENT_SECRET=replace-me
PAYPAL_WEBHOOK_ID=replace-me
PAYPAL_PLAN_PREMIUM_ID=replace-me
PAYPAL_PLAN_VIP_ID=replace-me
PAYPAL_MODE=live

XENDIT_SECRET_KEY=replace-me
XENDIT_WEBHOOK_TOKEN=replace-me
XENDIT_PLAN_PREMIUM_ID=replace-me
XENDIT_PLAN_VIP_ID=replace-me
XENDIT_MODE=live

PAYMONGO_API_KEY=replace-me
PAYMONGO_WEBHOOK_SECRET=replace-me
PAYMONGO_MODE=live

CHECKOUT_SUCCESS_URL=https://tradara.sagestonelab.tech/checkout/success
CHECKOUT_CANCEL_URL=https://tradara.sagestonelab.tech/checkout/cancel
